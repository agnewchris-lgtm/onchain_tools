# Copy to .env and fill secrets for local Docker deployment.

# Redis is provided by docker-compose. Override only if not using compose.
REDIS_URL=redis://redis:6379/0

# Optional: existing raw scanner Telegram group alerts.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ENABLE_TELEGRAM=true

# Optional but recommended for follower/profile enrichment inside the scanner.
# Hermes will still do deeper X research after receiving the alert.
TWITTERAPI_KEY=

# Forward every fired scanner alert to Hermes running on this same host.
# In Docker, host.docker.internal resolves to the host via docker-compose extra_hosts.
ABOT_WEBHOOK_URL=http://host.docker.internal:8644/webhooks/onchain-alerts
ABOT_PROXY_TOKEN=

# Scanner/runtime settings.
LOG_LEVEL=INFO

# Optional buy-button/private-key settings. Leave empty unless you intentionally enable buys.
SOLANA_PRIVATE_KEY=
EVM_PRIVATE_KEY=
BUY_AMOUNT_USD=50
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
